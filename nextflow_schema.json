{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/BioimageAnalysisCoreWEHI/extract_channel_images/main/nextflow_schema.json",
  "title": "extract_channel_images pipeline parameters",
  "description": "Extract individual channel TIFF images from COMET, MIBI, and OPAL datasets",
  "type": "object",
  "$defs": {
    "input_output_options": {
      "title": "Input/output options",
      "type": "object",
      "description": "Define where to find input TIFF images and where to write output channels.",
      "required": ["input_dir", "outdir"],
      "properties": {
        "input_dir": {
          "type": "string",
          "format": "directory-path",
          "exists": true,
          "description": "Directory containing input TIFF images."
        },
        "pattern": {
          "type": "string",
          "default": "*.{tif,tiff,ome.tif,ome.tiff,qptiff,qptif}",
          "description": "Glob pattern used to select TIFF files in input_dir."
        },
        "marker_mapping": {
          "type": "string",
          "format": "file-path",
          "exists": true,
          "description": "Optional JSON file mapping raw channel names to output names."
        },
        "outdir": {
          "type": "string",
          "format": "directory-path",
          "description": "Directory where output channel folders are written."
        },
        "publish_dir_mode": {
          "type": "string",
          "default": "copy",
          "description": "Method used by Nextflow publishDir when writing results.",
          "enum": ["symlink", "rellink", "link", "copy", "copyNoFollow", "move"]
        }
      }
    },
    "generic_options": {
      "title": "Generic options",
      "type": "object",
      "properties": {
        "validate_params": {
          "type": "boolean",
          "default": true,
          "description": "Validate pipeline parameters against nextflow_schema.json",
          "hidden": true
        }
      }
    }
  },
  "allOf": [
    {
      "$ref": "#/$defs/input_output_options"
    },
    {
      "$ref": "#/$defs/generic_options"
    }
  ]
}
