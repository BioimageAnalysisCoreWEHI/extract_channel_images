manifest {
    name = 'extract_channel_images'
    description = 'Extract per-channel TIFF images from COMET, MIBI, and OPAL TIFF files'
    author = 'WEHI SODA Hub'
    version = '0.1.0'
    mainScript = 'main.nf'
    nextflowVersion = '!>=24.04.0'
}

process {
    executor = 'local'
    cpus = 2
    memory = '4 GB'
}

docker.enabled = false
singularity.enabled = false
conda.enabled = false

profiles {
    conda {
        conda.enabled = true
        docker.enabled = false
        singularity.enabled = false
    }
    docker {
        docker.enabled = true
        conda.enabled = false
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        conda.enabled = false
        docker.enabled = false
        apptainer.enabled = false
    }
    apptainer {
        apptainer.enabled = true
        apptainer.autoMounts = true
        conda.enabled = false
        docker.enabled = false
        singularity.enabled = false
    }
    test {
        includeConfig 'conf/test.config'
        conda.enabled = true
        docker.enabled = false
        singularity.enabled = false
    }

    // For images up to ~150GB
    small {
        process {
            executor = 'slurm'  // Change to 'pbspro', 'lsf', or 'local' if needed
            queue = 'regular'   // Change to your HPC queue name

            withLabel: 'process_medium' {
                cpus   = { 1 }
                memory = { 24.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_high' {
                cpus   = { 1 }
                memory = { 36.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_single' {
                cpus   = { 1 }
                memory = { 36.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_multi' {
                cpus   = { 8 }
                memory = { 36.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_gpu' {
                cpus   = { 8 }
                memory = { 36.GB * task.attempt }
                time   = { 48.h }
                queue  = 'gpuq'
                clusterOptions = '--gres=gpu:1'
                containerOptions = {
                    if (workflow.containerEngine == 'singularity' || workflow.containerEngine == 'apptainer') {
                        return '--nv'
                    } else if (workflow.containerEngine == 'docker') {
                        return '--gpus all'
                    } else {
                        return ''
                    }
                }
            }
        }
        executor {
            queueSize = 10
            submitRateLimit = '10 sec'
        }
    }

    // For images up to ~300GB
    medium {
        process {
            executor = 'slurm'  // Change to 'pbspro', 'lsf', or 'local' if needed
            queue = 'regular'   // Change to your HPC queue name

            withLabel: 'process_medium' {
                cpus   = { 1 }
                memory = { 48.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_high' {
                cpus   = { 1 }
                memory = { 72.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_single' {
                cpus   = { 1 }
                memory = { 72.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_multi' {
                cpus   = { 16 }
                memory = { 72.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_gpu' {
                cpus   = { 8 }
                memory = { 72.GB * task.attempt }
                time   = { 48.h }
                queue  = 'gpuq'
                clusterOptions = '--gres=gpu:1'
                containerOptions = {
                    if (workflow.containerEngine == 'singularity' || workflow.containerEngine == 'apptainer') {
                        return '--nv'
                    } else if (workflow.containerEngine == 'docker') {
                        return '--gpus all'
                    } else {
                        return ''
                    }
                }
            }
        }
        executor {
            queueSize = 10
            submitRateLimit = '10 sec'
        }
    }

    // For images up to ~600GB
    large {
        process {
            executor = 'slurm'  // Change to 'pbspro', 'lsf', or 'local' if needed
            queue = 'regular'   // Change to your HPC queue name

            withLabel: 'process_medium' {
                cpus   = { 1 }
                memory = { 192.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_high' {
                cpus   = { 1 }
                memory = { 288.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_single' {
                cpus   = { 1 }
                memory = { 288.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_multi' {
                cpus   = { 32 }
                memory = { 288.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_gpu' {
                cpus   = { 8 }
                memory = { 288.GB * task.attempt }
                time   = { 48.h }
                queue  = 'gpuq'
                clusterOptions = '--gres=gpu:1'
                containerOptions = {
                    if (workflow.containerEngine == 'singularity' || workflow.containerEngine == 'apptainer') {
                        return '--nv'
                    } else if (workflow.containerEngine == 'docker') {
                        return '--gpus all'
                    } else {
                        return ''
                    }
                }
            }
        }
        executor {
            queueSize = 10
            submitRateLimit = '10 sec'
        }
    }
}
